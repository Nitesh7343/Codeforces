import java.util.Scanner;

public class Main {
	public static void main(String[] args) {
		Scanner scanner = new Scanner(System.in);
		int t = scanner.nextInt(); // Number of test cases
		while (t-- > 0) {
			int n = scanner.nextInt(); // Length of the array
			int[] a = new int[n]; // Array to store the elements
			for (int i = 0; i < n; i++) {
				a[i] = scanner.nextInt(); // Input array elements
			}
			// Inputs are read into the array

			int totalXor = 0; // Variable to store the XOR of all elements
			for (int i = 0; i < n; i++) {
				totalXor ^= a[i]; // XOR operation
			}
			// XOR of all elements in the array is calculated

			if (n % 2 == 1) { // Check if the number of elements is odd
				System.out.println(totalXor); // Output the XOR if n is odd
			} else { // If the number of elements is even
				if (totalXor == 0) { // Check if the total XOR is zero
					System.out.println(totalXor); // Output zero if total XOR is zero
				} else {
					System.out.println(-1); // Output -1 if total XOR is not zero
				}
			}
		}
		scanner.close();
	}
}

// Time Complexity (TC): O(n) = O(1000)
// Space Complexity (SC): O(n) = O(1000)
